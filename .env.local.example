# xAI API Key for stock analysis (using Grok model)
XAI_API_KEY=your_xai_api_key_here

# HTTP/HTTPS Proxy (如果需要通过代理访问xAI API)
# 常见代理端口: 7890 (Clash), 1080 (V2Ray), 10809 (Shadowsocks)
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# Stock API (using Alpha Vantage as example - free tier available)
STOCK_API_KEY=your_alpha_vantage_api_key_here

# Cookie secret for user sessions
COOKIE_SECRET=your_random_secret_key_here
